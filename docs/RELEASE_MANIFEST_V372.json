{
  "schema": "sc-site-intelligence-release-governance/1.0",
  "version": "3.13.0",
  "release": "Analytics and Public-Value Measurement",
  "aggregate_counters_only": true,
  "raw_events_stored": false,
  "individual_user_tracking": false,
  "persistent_visitor_identifier": false,
  "cookies_required": false,
  "ip_addresses_stored": false,
  "user_agents_stored": false,
  "referrers_stored": false,
  "page_paths_stored": false,
  "free_text_stored": false,
  "advertising_profiles": false,
  "cross_site_tracking": false,
  "maximum_batch_events": 25,
  "maximum_count_per_event": 25,
  "default_retention_days": 90,
  "public_summary_excludes_signal_level_counters": true,
  "admin_summary_remains_aggregate": true,
  "source_reliability_combines_operational_health_and_aggregate_engagement": true,
  "click_through_rate_only": false
}
