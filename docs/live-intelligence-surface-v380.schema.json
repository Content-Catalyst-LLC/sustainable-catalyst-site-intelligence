{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://sustainablecatalyst.com/schemas/live-intelligence-surface-v380.schema.json",
  "title": "Sustainable Catalyst Live Intelligence Surface",
  "type": "object",
  "required": ["surface_id", "label", "default_limit", "maximum_limit", "presentation", "allowed_destinations"],
  "properties": {
    "surface_id": {
      "type": "string",
      "enum": ["homepage", "static_strip", "channel", "publication", "library", "advisory", "lab", "external_embed"]
    },
    "label": {"type": "string", "minLength": 1},
    "description": {"type": "string"},
    "default_channel": {"type": "string"},
    "default_limit": {"type": "integer", "minimum": 1, "maximum": 12},
    "maximum_limit": {"type": "integer", "minimum": 1, "maximum": 12},
    "presentation": {"type": "string", "enum": ["ticker", "static", "manual"]},
    "reduced_motion": {"type": "string", "enum": ["static", "manual"]},
    "mobile_mode": {"type": "string", "enum": ["rotator", "stacked", "marquee", "hidden"]},
    "allowed_families": {"type": "array", "items": {"type": "string"}, "uniqueItems": true},
    "allowed_destinations": {"type": "array", "items": {"type": "string"}, "uniqueItems": true},
    "record_rotation_history": {"type": "boolean"},
    "embed_allowed": {"type": "boolean"},
    "shortcode": {"type": "string"},
    "placement": {"type": "string"}
  },
  "additionalProperties": true
}
