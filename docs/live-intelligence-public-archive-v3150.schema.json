{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://sustainablecatalyst.com/schemas/live-intelligence-public-archive-v3150.schema.json",
  "title": "Live Intelligence Public Archive Record",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema",
    "release_version",
    "archive_id",
    "source_type",
    "source_id",
    "source_sha256",
    "record_sha256",
    "retention_class",
    "status",
    "source_record_mutated",
    "archive_record_deleted",
    "destination_write_performed",
    "remote_deposit_performed"
  ],
  "properties": {
    "schema": {"type": "string", "const": "sc-site-intelligence-public-archive-record/1.0"},
    "release_version": {"type": "string", "const": "3.17.0"},
    "archive_id": {"type": "string", "minLength": 1, "maxLength": 180},
    "source_type": {"enum": ["publication_release", "public_change_notice", "public_briefing"]},
    "source_id": {"type": "string", "minLength": 1, "maxLength": 180},
    "title": {"type": "string", "minLength": 1, "maxLength": 500},
    "preservation_note": {"type": "string", "maxLength": 4000},
    "retention_class": {"enum": ["permanent", "ten_year", "seven_year"]},
    "review_due_at": {"type": "string", "maxLength": 80},
    "source_sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
    "record_sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
    "previous_archive_id": {"type": "string", "maxLength": 180},
    "previous_record_sha256": {"type": "string", "pattern": "^$|^[a-f0-9]{64}$"},
    "status": {"enum": ["draft", "verified", "approved"]},
    "public_visible": {"type": "boolean"},
    "preservation_manifest_sha256": {"type": "string", "pattern": "^$|^[a-f0-9]{64}$"},
    "source_record_mutated": {"type": "boolean", "const": false},
    "archive_record_deleted": {"type": "boolean", "const": false},
    "destination_write_performed": {"type": "boolean", "const": false},
    "remote_deposit_performed": {"type": "boolean", "const": false}
  }
}
