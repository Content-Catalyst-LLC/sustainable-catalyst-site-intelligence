{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://sustainablecatalyst.com/schemas/live-intelligence-briefing-v3100.schema.json",
  "title": "Live Intelligence Briefing",
  "type": "object",
  "required": ["schema", "briefing_id", "briefing_type", "title", "status", "claims", "evidence", "limitations"],
  "properties": {
    "schema": {"const": "sc-site-intelligence-live-intelligence-briefing/1.0"},
    "briefing_id": {"type": "string", "minLength": 1},
    "briefing_type": {"enum": ["signal", "alert", "digest", "channel", "regional"]},
    "title": {"type": "string", "minLength": 1},
    "status": {"enum": ["draft", "approved", "rejected"]},
    "claims": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["claim_id", "text", "source_refs", "causal_inference"],
        "properties": {
          "claim_id": {"type": "string"},
          "text": {"type": "string"},
          "source_refs": {"type": "array", "minItems": 1, "items": {"type": "string"}},
          "causal_inference": {"const": false}
        }
      }
    },
    "evidence": {"type": "array", "minItems": 1},
    "limitations": {"type": "array", "minItems": 1, "items": {"type": "string"}},
    "automatic_publication": {"const": false},
    "automatic_wordpress_write": {"const": false}
  }
}
