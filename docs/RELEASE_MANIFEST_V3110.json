{
  "schema": "sc-site-intelligence-release-governance/1.0",
  "version": "3.13.0",
  "release": "Editorial Workspace, Review Queues, and Publication Orchestration",
  "source_linked_briefings": true,
  "editorial_assignments": true,
  "revision_history_retained": true,
  "separation_of_duties": true,
  "supported_roles": ["author", "editor", "fact_checker", "legal_reviewer", "publisher"],
