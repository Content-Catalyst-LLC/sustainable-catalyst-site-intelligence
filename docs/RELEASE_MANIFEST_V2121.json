    "source_window_checked": true,
    "desktop_minimum_height": 620,
    "mobile_minimum_height": 760,
    "maximum_height": 2600,
    "new_tab_fallback": true
  },
  "offline_freshness_guaranteed": false,
  "accessibility_target": "WCAG 2.2 Level AA target; not a third-party certification",
  "accessibility_certification": "none",
  "server_user_tracking": false,
  "paid_api_required": false,
  "paid_cache_required": false,
  "new_server_required": false,
  "workspace_count": 21,
  "auditable_artifact_count": 20
