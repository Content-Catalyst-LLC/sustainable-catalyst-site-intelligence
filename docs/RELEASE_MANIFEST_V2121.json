{
  "version": "2.12.1",
  "release": "Production Offline, Mobile, and Embed Reliability Patch",
  "route": "/app/?view=experience",
  "shortcodes": [
    "[sc_site_intelligence_app height=\"1000\"]",
    "[sc_offline_mobile_accessibility_performance height=\"1500\"]",
    "[sc_site_intelligence_embed view=\"experience\" height=\"1000\"]"
  ],
  "public_endpoints": [
    "/public/offline-experience",
    "/public/offline-experience/cache-plan",
    "/public/offline-experience/accessibility",
    "/public/offline-experience/performance",
    "/public/offline-experience/diagnostics",
    "/public/offline-experience/reliability"
  ],
  "pwa": {
    "manifest": "/app/manifest.webmanifest",
    "service_worker": "/app/service-worker.js",
    "offline_fallback": "/app/offline.html",
    "scope": "/app/",
    "release_scoped_cache": "scsi-v2.12.1",
    "partial_install_recovery": true,
    "navigation_preload": true,
    "old_release_cache_cleanup": true
  },
  "cache": {
    "public_maximum_entries": 120,
    "public_maximum_age_hours": 24,
    "bounded": true,
    "age_limited": true,
    "browser_local": true
