{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://sustainablecatalyst.com/schemas/live-intelligence-registry-publications-v3220.schema.json",
  "title": "Live Intelligence Registry Research Brief",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema",
    "release_version",
    "brief_id",
    "collection_id",
    "source_collection_sha256",
    "title",
    "abstract",
    "key_findings",
    "methodology",
    "limitations",
    "citations",
    "status",
    "brief_sha256"
  ],
  "properties": {
    "schema": {
      "const": "sc-site-intelligence-registry-research-brief/1.0"
    },
    "release_version": {
      "const": "3.22.0"
    },
    "brief_id": {
      "type": "string",
      "minLength": 1
    },
    "collection_id": {
      "type": "string",
      "minLength": 1
    },
    "source_collection_sha256": {
      "type": "string",
      "pattern": "^[a-f0-9]{64}$"
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "deck": {
      "type": "string"
    },
    "abstract": {
      "type": "string",
      "minLength": 1
    },
    "key_findings": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      }
    },
    "methodology": {
      "type": "string",
      "minLength": 1
    },
    "limitations": {
      "type": "string",
      "minLength": 1
    },
    "citations": {
      "type": "array",
      "items": {
        "type": "object"
      }
    },
    "status": {
      "enum": [
        "draft",
        "reviewed",
        "approved"
      ]
    },
    "brief_sha256": {
      "type": "string",
      "pattern": "^[a-f0-9]{64}$"
    }
  }
}
