# Sustainable Catalyst Site Intelligence
SC_SI_ENVIRONMENT=development
SC_SI_DEMO_MODE=true
SC_SI_API_TOKEN=dev-token-change-me
SC_SI_CORS_ORIGINS=http://127.0.0.1:8091,http://localhost:8091,https://sustainablecatalyst.com
SC_SI_CACHE_TTL_SECONDS=900
SC_SI_REGISTRY_PATH=backend/data/site_registry.seed.json

# GA4 integration. Leave blank for demo mode.
SC_SI_GA4_PROPERTY_ID=
SC_SI_GOOGLE_APPLICATION_CREDENTIALS_JSON=
SC_SI_GOOGLE_APPLICATION_CREDENTIALS_FILE=

# External Data Connectors v0.2.1
SC_SI_EXTERNAL_LIVE=true
SC_SI_EXTERNAL_REQUEST_TIMEOUT_SECONDS=8
SC_SI_EXTERNAL_CACHE_ENABLED=true
SC_SI_EXTERNAL_CACHE_TTL_SECONDS=1800
SC_SI_EXTERNAL_STALE_TTL_SECONDS=86400
SC_SI_EXTERNAL_REGISTRY_PATH=backend/data/external_connectors.seed.json
SC_SI_EXTERNAL_DEFAULT_LATITUDE=41.8781
SC_SI_EXTERNAL_DEFAULT_LONGITUDE=-87.6298
SC_SI_EXTERNAL_DEFAULT_COUNTRY=USA
SC_SI_NASA_POWER_BASE_URL=https://power.larc.nasa.gov/api/temporal/daily/point
SC_SI_NASA_GIBS_WMTS_CAPABILITIES_URL=https://gibs.earthdata.nasa.gov/wmts/epsg3857/best/1.0.0/WMTSCapabilities.xml
SC_SI_CLIMATE_TRACE_BASE_URL=https://api.climatetrace.org/v6

# Search Console / SEO Intelligence v0.3.0
SC_SI_SEARCH_CONSOLE_LIVE=true
SC_SI_SEARCH_CONSOLE_SITE_URL=https://sustainablecatalyst.com/
SC_SI_SEARCH_CONSOLE_MAX_ROWS=250
SC_SI_SEARCH_CONSOLE_TIMEOUT_SECONDS=10

# Sitemap / Indexing Intelligence
SC_SI_SITEMAP_LIVE=true
SC_SI_SITEMAP_URL=https://sustainablecatalyst.com/sitemap.xml
SC_SI_SITEMAP_TIMEOUT_SECONDS=10
SC_SI_SITEMAP_MAX_URLS=500
SC_SI_SITE_BASE_URL=https://sustainablecatalyst.com

# Publishing Intelligence defaults are query-level, not environment-only.
# Current window defaults to 28daysAgo/yesterday and comparison defaults to 56daysAgo/29daysAgo.

# v0.5.0 Public Dashboard Framework
SC_SI_PUBLIC_DASHBOARDS_ENABLED=true
SC_SI_PUBLIC_METRICS_ROUNDING_BUCKET=100
SC_SI_PUBLIC_SHOW_EXACT_COUNTS=false
SC_SI_PUBLIC_DEFAULT_MODE=summary

# v0.8.0 AI-Assisted Intelligence Briefs
# Disabled by default. Deterministic fallback briefs work without an external model.
SC_SI_AI_PROVIDER=disabled
SC_SI_GEMINI_API_KEY=
SC_SI_GEMINI_MODEL=gemini-1.5-flash
SC_SI_AI_TEMPERATURE=0.2
SC_SI_AI_MAX_OUTPUT_TOKENS=1200
SC_SI_AI_TIMEOUT_SECONDS=12

# v1.6.0 Sustainable Development Data Connectors
SC_SI_SUSTAINABLE_DEVELOPMENT_CONNECTORS_ENABLED=true
SC_SI_SUSTAINABLE_DEVELOPMENT_LIVE_CHECKS=false
SC_SI_SUSTAINABLE_DEVELOPMENT_CACHE_TTL_SECONDS=21600

# v1.8.0 Connector Reliability
SC_SI_SUSTAINABLE_DEVELOPMENT_STALE_TTL_SECONDS=604800
SC_SI_SUSTAINABLE_DEVELOPMENT_RETRY_ATTEMPTS=3
SC_SI_SUSTAINABLE_DEVELOPMENT_RETRY_BACKOFF_SECONDS=0.25
SC_SI_SUSTAINABLE_DEVELOPMENT_CIRCUIT_BREAKER_FAILURES=3
SC_SI_SUSTAINABLE_DEVELOPMENT_CIRCUIT_BREAKER_SECONDS=300

# v1.8.0 Connector Reliability
SC_SI_SUSTAINABLE_DEVELOPMENT_STALE_TTL_SECONDS=604800
SC_SI_SUSTAINABLE_DEVELOPMENT_RETRY_ATTEMPTS=3
SC_SI_SUSTAINABLE_DEVELOPMENT_RETRY_BACKOFF_SECONDS=0.25
SC_SI_SUSTAINABLE_DEVELOPMENT_CIRCUIT_BREAKER_FAILURES=3
SC_SI_SUSTAINABLE_DEVELOPMENT_CIRCUIT_BREAKER_SECONDS=300


# Platform Core v2.5.0 integration — v1.15.1
# Use the deployed Platform Core backend URL, not the WordPress page URL.
SC_SI_PLATFORM_CORE_ENABLED=false
SC_SI_PLATFORM_CORE_URL=
SC_SI_PLATFORM_CORE_WRITE_API_KEY=
SC_SI_PLATFORM_CORE_PUBLIC_API_KEY=
SC_SI_PLATFORM_CORE_TIMEOUT_SECONDS=5
SC_SI_PLATFORM_CORE_QUEUE_PATH=backend/data/platform_core_queue.jsonl
SC_SI_PLATFORM_CORE_PUBLIC_EVIDENCE_URL=

# v1.20.0 Public Briefing and Export Studio
# Optional. Defaults to backend/data/country_last_known_good.json.
# Render's filesystem is ephemeral; this is best-effort runtime persistence, not durable storage.
SC_SI_COUNTRY_CACHE_PATH=

# Site Intelligence v2.1.0 — Core-powered public global conditions
SC_SI_GLOBAL_CONDITIONS_ENABLED=true
SC_SI_PLATFORM_CORE_ENABLED=false
SC_SI_PLATFORM_CORE_URL=
SC_SI_PLATFORM_CORE_PUBLIC_API_KEY=
SC_SI_GLOBAL_CONDITIONS_TIMEOUT_SECONDS=9
SC_SI_GLOBAL_CONDITIONS_CACHE_TTL_SECONDS=90

# Site Intelligence v2.2.0 — Economics, Markets, and Sustainability Signals
SC_SI_ECONOMICS_SUSTAINABILITY_ENABLED=true
SC_SI_ECONOMICS_SUSTAINABILITY_TIMEOUT_SECONDS=9
SC_SI_ECONOMICS_SUSTAINABILITY_CACHE_TTL_SECONDS=120

# Site Intelligence v2.3.0 — International Law and Global Governance Observatory
SC_SI_INTERNATIONAL_LAW_OBSERVATORY_ENABLED=true
SC_SI_INTERNATIONAL_LAW_OBSERVATORY_TIMEOUT_SECONDS=9
SC_SI_INTERNATIONAL_LAW_OBSERVATORY_CACHE_TTL_SECONDS=120
SC_SI_SCIENTIFIC_EARTH_SYSTEMS_ENABLED=true
SC_SI_SCIENTIFIC_EARTH_SYSTEMS_TIMEOUT_SECONDS=9
SC_SI_SCIENTIFIC_EARTH_SYSTEMS_CACHE_TTL_SECONDS=120

# Site Intelligence v2.5.0 — Humanitarian, Conflict, and Displacement Observatory
SC_SI_HUMANITARIAN_CONFLICT_DISPLACEMENT_ENABLED=true
SC_SI_HUMANITARIAN_CONFLICT_DISPLACEMENT_TIMEOUT_SECONDS=9
SC_SI_HUMANITARIAN_CONFLICT_DISPLACEMENT_CACHE_TTL_SECONDS=90

# Site Intelligence v2.6.0 — Trade, Energy, and Resource Security Observatory
SC_SI_TRADE_ENERGY_RESOURCE_SECURITY_ENABLED=true
SC_SI_TRADE_ENERGY_RESOURCE_SECURITY_TIMEOUT_SECONDS=9
SC_SI_TRADE_ENERGY_RESOURCE_SECURITY_CACHE_TTL_SECONDS=120


# Site Intelligence v2.7.0 — Unified Country and Regional Intelligence Dossiers
SC_SI_UNIFIED_DOSSIERS_ENABLED=true
SC_SI_UNIFIED_DOSSIERS_MAX_RECORDS_PER_DOMAIN=40

# Site Intelligence v2.8.0 — Alerts, Monitoring, and Live Intelligence Streams
SC_SI_ALERTS_MONITORING_ENABLED=true
SC_SI_ALERTS_STREAM_RECONNECT_SECONDS=30
SC_SI_ALERTS_STREAM_MAX_SIGNALS=180
SC_SI_ALERTS_STALE_SOURCE_HOURS=72

# Site Intelligence v2.9.0 — Comparative Intelligence and Scenario Studio
SC_SI_COMPARATIVE_SCENARIO_STUDIO_ENABLED=true
SC_SI_COMPARATIVE_SCENARIO_MAX_GEOGRAPHIES=5
SC_SI_COMPARATIVE_SCENARIO_MAX_INDICATORS=12
SC_SI_COMPARATIVE_SCENARIO_MAX_RECORDS=400

# v2.10.0 optional environment values:
SC_SI_RESEARCH_WORKFLOWS_ENABLED=true
SC_SI_RESEARCH_WORKFLOWS_MAX_INVESTIGATIONS=30
SC_SI_RESEARCH_WORKFLOWS_MAX_EVIDENCE_ITEMS=120
SC_SI_RESEARCH_WORKFLOWS_MAX_NOTES=80

# Site Intelligence v2.11.0 public integration
SC_SI_PUBLIC_DATA_API_ENABLED=true
SC_SI_PUBLIC_DATA_API_MAX_LIMIT=200
SC_SI_PUBLIC_EMBEDS_ENABLED=true
SC_SI_PUBLIC_EMBED_ALLOWED_ORIGINS=
SC_SI_INSTITUTION_NAME=Sustainable Catalyst
SC_SI_INSTITUTION_WEBSITE=https://sustainablecatalyst.com
SC_SI_INSTITUTION_LOGO_URL=
SC_SI_INSTITUTION_CONTACT=
SC_SI_INSTITUTION_ACCENT=#8b1e3f

# Site Intelligence v2.12.0 offline, mobile, accessibility, and performance
SC_SI_OFFLINE_EXPERIENCE_ENABLED=true
SC_SI_SERVICE_WORKER_ENABLED=true
SC_SI_OFFLINE_CACHE_MAX_ENTRIES=120
SC_SI_OFFLINE_CACHE_TTL_HOURS=24
SC_SI_LOW_BANDWIDTH_DEFAULT=false


# Site Intelligence v2.13.0 connector operations and ingestion control center
SC_SI_CONNECTOR_OPERATIONS_ENABLED=true
SC_SI_CONNECTOR_OPERATIONS_REGISTRY_PATH=backend/data/connector_operations_registry_v2130.json
SC_SI_CONNECTOR_OPERATIONS_STATE_PATH=backend/data/connector_operations_state_v2130.json
